{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "reporters": ["clear-text", "progress"],
  "ignorePatterns": [
    ".claude",
    "_bmad",
    ".bmad-loop",
    "design-artifacts",
    "docs",
    ".next",
    "e2e",
    "coverage",
    "reports",
    ".stryker-tmp",
    "playwright-report",
    "test-results",
    "src/adapters/db/generated"
  ],
  "coverageAnalysis": "perTest",
  "mutate": ["src/domain/**/*.{ts,tsx}", "!src/domain/**/*.{test,spec}.{ts,tsx}"],
  "thresholds": {
    "high": 100,
    "low": 100,
    "break": 100
  }
}
