{
  "name": "payroll",
  "version": "0.1.0",
  "private": true,
  "description": "Salary Management for ACME HR — hand-scaffolded Next.js 16 app (functional core / imperative shell).",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "test:a11y": "playwright test e2e/accessibility.spec.ts",
    "test:smoke": "playwright test e2e/smoke.spec.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:tokens": "playwright test e2e/tokens.spec.ts",
    "test:shell": "playwright test e2e/shell.spec.ts",
    "test:browser": "playwright test e2e/accessibility.spec.ts e2e/tokens.spec.ts e2e/shell.spec.ts",
    "tokens:build": "node scripts/generate-design-tokens.ts",
    "tokens:check": "node scripts/generate-design-tokens.ts --check",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@fontsource/hanken-grotesk": "5.3.0",
    "@fontsource/jetbrains-mono": "5.3.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "dotenv": "17.2.4",
    "next": "16.2.10",
    "prisma": "7.8.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-import-resolver-typescript": "3.10.1",
    "eslint-plugin-import": "2.32.0",
    "pg": "8.22.0",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  }
}
