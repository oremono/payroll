.bmad-loop/runs/
.bmad-loop/cache/
.bmad-loop/policy.toml

# Personal BMAD install answers (user_name, language) — not shared with the team
_bmad/config.user.toml

# Personal application context — not part of the solution
_job_desc.md

# ─── Node / Next.js ───────────────────────────────────────────────
# dependencies
node_modules/
.pnp
.pnp.*

# next.js build output
.next/
out/
build/
next-env.d.ts

# typescript
*.tsbuildinfo

# testing / coverage
coverage/
.vitest/

# mutation testing (Stryker) — root-anchored so a future src/**/reports/ feature dir stays tracked
/reports/
/.stryker-tmp/

# playwright (accessibility gate) — root-anchored for the same reason
/test-results/
/playwright-report/
/.playwright/

# prisma generated client — the v7 `prisma-client` generator emits TypeScript SOURCE (not a
# compiled package in node_modules), so this is thousands of generated .ts files under src/.
# It is excluded from FIVE places, this being one: .gitignore, eslint.config.mjs `ignores`,
# vitest coverage, stryker `ignorePatterns`, and tsconfig.json `exclude`. Regenerate with
# `npm run db:generate` (also wired to `postinstall`).
/src/adapters/db/generated/

# environment (keep .env.example if added)
.env
.env.*
!.env.example

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# vercel cli — created by `vercel deploy` / `vercel pull`; holds local project linkage
.vercel/

# NOTE: the Vercel CLI also appends `.vercel` and `.env*` here. Both were removed (story 1-7):
# `.vercel` is redundant with `.vercel/`, and `.env*` sits AFTER the `!.env.example` negation
# above, so — last matching pattern wins — it silently re-ignored .env.example. That file only
# survived because it was already tracked; in a fresh clone `git add .env.example` would have been
# refused. If the CLI re-appends this block, delete it again rather than negating around it.
