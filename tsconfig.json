{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "allowJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    // Node 24 runs `scripts/**` DIRECTLY via native type-stripping, and Node's ESM loader needs a
    // full specifier — so those modules import each other as `./to-css.ts`. Safe under `noEmit`:
    // nothing is ever written, so no emitted specifier can point at a non-existent `.ts` file.
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/domain/*": [
        "./src/domain/*"
      ],
      "@/application/*": [
        "./src/application/*"
      ],
      "@/adapters/*": [
        "./src/adapters/*"
      ],
      "@/app/*": [
        "./src/app/*"
      ],
      "@/ui/*": [
        "./src/ui/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".claude",
    "_bmad",
    ".bmad-loop",
    "design-artifacts",
    "docs",
    "src/adapters/db/generated"
  ]
}
